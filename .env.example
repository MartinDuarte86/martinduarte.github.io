# ─── Claude / Anthropic ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── OpenRouter (solo para pruebas locales con mock-server.js) ─
# Define LLM_PROVIDER=openrouter para que el mock-server redirija
# las llamadas a /api/claude a OpenRouter en lugar de mockearlas.
# Usar SOLO modelos gratuitos (sufijo :free) — DeepSeek o NVIDIA.
# No afecta a producción: api/claude.js sigue usando Anthropic.
# LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free

# ─── GitHub REST API (para clientes.json y dsn/) ─────────────
GH_TOKEN=ghp_...
GH_OWNER=MartinDuarte86
GH_REPO=MarcaPersonal-Web

# ─── Validación de email ─────────────────────────────────────
ABSTRACT_API_KEY=...

# ─── Notificaciones por email ────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Landing Bot <noreply@martinduarte.com>

# ─── Sesión (cookie httpOnly firmada) ────────────────────────
# Obligatorio en producción: firma la cookie de sesión que ata un session_id a
# cada navegador (api/_lib/session.js). Generar uno largo y aleatorio.
SESSION_SECRET=

# ─── URL base (auto-provista por Vercel en producción) ───────
# BASE_URL=https://tu-dominio.vercel.app
